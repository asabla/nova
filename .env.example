# ─── NOVA Environment Configuration ───────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
APP_VERSION=0.1.0
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ───────────────────────────
DATABASE_URL=postgres://nova:nova@localhost:5432/nova

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── RustFS (S3-compatible storage) ───────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nova-files

# ─── LLM Provider Keys ────────────────────────────────
# At least one is required for LLM functionality.
# These are used as fallback when no provider is configured in the DB.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Local Model (LM Studio / Ollama / etc.) ────────
# Optional: configure as a provider in the Nova UI, or set env vars:
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=not-needed

# ─── Temporal (workflow engine) ──────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ─── Auth (Better Auth) ─────────────────────────────
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_CORS_ORIGIN=http://localhost:5174,http://localhost:5173,http://localhost:3000

# ─── SSO Providers (optional) ───────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# ─── Email (optional) ───────────────────────────────
# Provider: "console" (dev default), "smtp", or "resend"
EMAIL_PROVIDER=console
EMAIL_FROM="NOVA <noreply@nova.app>"
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=re_...

# ─── Stripe Billing (optional, SaaS mode) ───────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FREE=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ─── Observability (optional) ───────────────────────
# LangFuse - LLM tracing
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# Helicone - LLM analytics
# HELICONE_API_KEY=

# ─── Sandbox (Docker-based code execution) ────────
# Enable sandboxed code execution for agents.
# Uses the host Docker daemon to spin up ephemeral containers.
# Pre-pull images: docker compose up sandbox-init
SANDBOX_ENABLED=false
# SANDBOX_DOCKER_HOST=unix:///var/run/docker.sock

# ─── Worker-specific (optional overrides) ───────────
# SUMMARY_MODEL=gpt-5.4
# EMBEDDING_MODEL=text-embedding-3-small
# RESEARCH_MODEL=default-model
# SEARXNG_URL=

# ─── Observability (OpenTelemetry) ──────────────────
# Enable OTel instrumentation (traces, log correlation).
# Requires the observability stack: docker compose --profile observability up
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME is set per-service in docker-compose

# Grafana admin password (observability profile)
GRAFANA_ADMIN_PASSWORD=nova

# ─── Web (Vite, build-time only) ────────────────────
# Set if the API runs on a different origin than the web app.
# VITE_API_URL=
