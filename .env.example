# ─── Database ────────────────────────────────────
DATABASE_URL=postgres://nova:nova@localhost:5432/nova

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO (S3-compatible) ───────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nova-files

# ─── LiteLLM Proxy ──────────────────────────────
LITELLM_API_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-nova-litellm-dev

# ─── Temporal ────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ─── Auth ────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# ─── CORS ────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── API Keys (for LiteLLM) ─────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Email ──────────────────────────────────────
EMAIL_PROVIDER=console
EMAIL_FROM=NOVA <noreply@nova.app>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=re_...

# ─── SSO (optional) ────────────────────────────
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Observability (optional) ──────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# ─── Billing / Stripe (optional, SaaS mode) ──────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FREE=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ─── Helicone (optional) ─────────────────────────
# HELICONE_API_KEY=

# ─── Server ──────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:5173
APP_VERSION=0.1.0
LOG_LEVEL=debug
