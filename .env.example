# ─── NOVA Environment Configuration ───────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
APP_VERSION=0.1.0
LOG_LEVEL=debug

# ─── Database (PostgreSQL + pgvector) ────────────────
DATABASE_URL=postgres://nova:nova@localhost:5432/nova

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO (S3-compatible storage) ───────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nova-files

# ─── LiteLLM Proxy ──────────────────────────────────
LITELLM_API_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-nova-litellm-dev
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=admin

# ─── LLM API Keys (used by LiteLLM) ─────────────────
# At least one is required for LLM functionality.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Local Model (LM Studio / Ollama / etc.) ────────
# Optional: point to a local inference server.
# Uncomment the "local" model entry in infra/docker/litellm-config.yaml too.
# LOCAL_MODEL_API_BASE=http://host.docker.internal:1234/v1
# LOCAL_MODEL_NAME=openai/my-local-model

# ─── Temporal (workflow engine) ──────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ─── Auth (Better Auth) ─────────────────────────────
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── SSO Providers (optional) ───────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# ─── Email (optional) ───────────────────────────────
# Provider: "console" (dev default), "smtp", or "resend"
EMAIL_PROVIDER=console
EMAIL_FROM="NOVA <noreply@nova.app>"
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=re_...

# ─── Stripe Billing (optional, SaaS mode) ───────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FREE=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ─── Observability (optional) ───────────────────────
# LangFuse - LLM tracing
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# Helicone - LLM analytics
# HELICONE_API_KEY=

# ─── Worker-specific (optional overrides) ───────────
# LITELLM_URL=http://localhost:4000
# SUMMARY_MODEL=lmstudio/gpt-oss:20b
# EMBEDDING_MODEL=lmstudio/text-embedding-nomic-embed-text-v1.5
# RESEARCH_MODEL=lmstudio/gpt-oss:20b
# SEARXNG_URL=

# ─── Web (Vite, build-time only) ────────────────────
# Set if the API runs on a different origin than the web app.
# VITE_API_URL=
