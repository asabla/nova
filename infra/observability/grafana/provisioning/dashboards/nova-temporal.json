{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row", "title": "Temporal Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false
    },
    {
      "type": "stat", "title": "Nova Workflows Dispatched",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(nova_workflows_dispatched_total) or vector(0)", "instant": true, "legendFormat": "" }],
      "fieldConfig": { "defaults": { "noValue": "0", "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "type": "stat", "title": "Persistence P95 Latency",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(persistence_latency_bucket[5m])) by (le))", "instant": true, "legendFormat": "" }],
      "fieldConfig": { "defaults": { "noValue": "0", "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] } } }
    },
    {
      "type": "stat", "title": "Service Errors",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(service_errors[5m])) or vector(0)", "instant": true, "legendFormat": "" }],
      "fieldConfig": { "defaults": { "noValue": "0", "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "type": "row", "title": "Service Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Service Request Rate by Operation",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, sum(rate(service_requests[5m])) by (operation))", "legendFormat": "{{operation}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "type": "timeseries", "title": "Service Errors by Type",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(service_error_with_type[5m])) by (error_type)", "legendFormat": "{{error_type}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "type": "row", "title": "Persistence",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Persistence Request Rate by Operation",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, sum(rate(persistence_requests[5m])) by (operation))", "legendFormat": "{{operation}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "type": "timeseries", "title": "Persistence Latency P95 by Operation",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(5, histogram_quantile(0.95, sum(rate(persistence_latency_bucket[5m])) by (le, operation)))", "legendFormat": "{{operation}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
    },
    {
      "type": "row", "title": "Connections",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "collapsed": false
    },
    {
      "type": "timeseries", "title": "SQL Connection Pool",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "persistence_sql_open_conn", "legendFormat": "open" },
        { "expr": "persistence_sql_in_use", "legendFormat": "in_use" },
        { "expr": "persistence_sql_idle_conn", "legendFormat": "idle" },
        { "expr": "persistence_sql_max_open_conn", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
    },
    {
      "type": "timeseries", "title": "Nova Workflow Dispatches Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(nova_workflows_dispatched_total[5m])) by (type)", "legendFormat": "{{type}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "lineWidth": 2, "drawStyle": "bars" } } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nova", "infrastructure", "temporal"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Nova Temporal",
  "uid": "nova-temporal",
  "version": 2
}
