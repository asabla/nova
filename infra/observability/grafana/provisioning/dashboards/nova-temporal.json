{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Workflows Started (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(workflow_started_total[5m])) or sum(increase(temporal_request_total{operation=\"StartWorkflowExecution\"}[5m]))", "legendFormat": "started", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Persistence P95 Latency",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(persistence_latency_bucket[5m])) by (le))", "legendFormat": "p95", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 0.5 }
          ]}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Operation",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(service_requests_total[5m])) by (operation)", "legendFormat": "{{operation}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } }
      }
    },
    {
      "type": "timeseries",
      "title": "Request Latency P95 by Operation",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(service_latency_bucket[5m])) by (le, operation))", "legendFormat": "{{operation}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "type": "timeseries",
      "title": "Errors by Type",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(service_errors_total[5m])) by (type)", "legendFormat": "{{type}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": [
          { "matcher": { "id": "byFrameRefID", "options": "A" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nova", "infrastructure", "temporal"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Nova Temporal",
  "uid": "nova-temporal",
  "version": 1
}
