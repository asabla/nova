{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Request Rate",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(nova_http_requests_total[5m]))", "legendFormat": "req/s", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(nova_http_requests_total{status=~\"[45]..\"}[5m])) / sum(rate(nova_http_requests_total[5m])) * 100 or vector(0)", "legendFormat": "error %", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "P95 Latency",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(nova_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Active WS Connections",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nova_ws_connections_active or vector(0)", "legendFormat": "connections", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Active Streams",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nova_streaming_requests_active or vector(0)", "legendFormat": "streams", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "purple", "value": null }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "HTTP Errors (5m)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(nova_http_requests_total{status=~\"[45]..\"}[5m])) or vector(0)", "legendFormat": "errors", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(nova_http_requests_total{status=~\"2..\"}[5m]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(nova_http_requests_total{status=~\"4..\"}[5m]))", "legendFormat": "4xx" },
        { "expr": "sum(rate(nova_http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Request Latency Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(nova_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(nova_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(nova_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "type": "timeseries",
      "title": "LLM Token Consumption",
      "description": "Populates when LLM calls are made (send a chat message to trigger)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(nova_llm_tokens_total{direction=\"prompt\"}[5m])) by (model)", "legendFormat": "prompt: {{model}}" },
        { "expr": "sum(rate(nova_llm_tokens_total{direction=\"completion\"}[5m])) by (model)", "legendFormat": "completion: {{model}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "lineWidth": 2, "stacking": { "mode": "normal" } } }
      }
    },
    {
      "type": "timeseries",
      "title": "Temporal Workflows Dispatched",
      "description": "Populates when workflows are dispatched (send a chat message or upload a file)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(nova_workflows_dispatched_total[5m])) by (type)", "legendFormat": "{{type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "lineWidth": 2, "stacking": { "mode": "normal" } } }
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Errors by Status Code",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(nova_http_requests_total{status=~\"4..\"}[5m])) by (status)", "legendFormat": "{{status}}" },
        { "expr": "sum(rate(nova_http_requests_total{status=~\"5..\"}[5m])) by (status)", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2, "drawStyle": "bars" } }
      }
    },
    {
      "type": "timeseries",
      "title": "Top Endpoints by Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, sum(rate(nova_http_requests_total[5m])) by (path))", "legendFormat": "{{path}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10, "lineWidth": 1 } }
      }
    },
    {
      "type": "logs",
      "title": "Recent Logs (all services)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{container=~\"nova-.*\"} | json", "legendFormat": "" }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nova", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Nova Platform Overview",
  "uid": "nova-overview",
  "version": 2
}
