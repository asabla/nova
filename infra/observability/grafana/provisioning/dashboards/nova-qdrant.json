{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row", "title": "Qdrant Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false
    },
    {
      "type": "stat", "title": "Collections",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "collections_total{job=\"qdrant\"}", "instant": true, "legendFormat": "" }],
      "fieldConfig": { "defaults": { "noValue": "0", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "type": "stat", "title": "Total Vectors",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(collections_vector_total{job=\"qdrant\"})", "instant": true, "legendFormat": "" }],
      "fieldConfig": { "defaults": { "noValue": "0", "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "type": "stat", "title": "REST Avg Latency",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "avg(rest_responses_avg_duration_seconds{job=\"qdrant\"})", "instant": true, "legendFormat": "" }],
      "fieldConfig": { "defaults": { "noValue": "0", "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "type": "row", "title": "REST API",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "collapsed": false
    },
    {
      "type": "timeseries", "title": "REST Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(rest_responses_total{job=\"qdrant\"}[5m])) by (method, status)", "legendFormat": "{{method}} {{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "type": "timeseries", "title": "REST Response Duration P95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(rest_responses_duration_seconds_bucket{job=\"qdrant\"}[5m])) by (le, method))", "legendFormat": "{{method}} p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
    },
    {
      "type": "row", "title": "Failures & Connections",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "collapsed": false
    },
    {
      "type": "timeseries", "title": "REST Failures",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(rest_responses_fail_total{job=\"qdrant\"}[5m])) by (method)", "legendFormat": "{{method}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "type": "timeseries", "title": "gRPC Connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "service_grpc_conn_active{job=\"qdrant\"}", "legendFormat": "active" },
        { "expr": "rate(service_grpc_conn_accepted{job=\"qdrant\"}[5m])", "legendFormat": "accepted/s" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nova", "infrastructure", "qdrant"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Nova Qdrant",
  "uid": "nova-qdrant",
  "version": 2
}
