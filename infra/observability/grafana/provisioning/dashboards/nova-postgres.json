{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "PostgreSQL Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pg_stat_activity_count{state=\"active\"})", "legendFormat": "active", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Database Size",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "pg_database_size_bytes{datname=\"nova\"}", "legendFormat": "nova", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5368709120 },
            { "color": "red", "value": 10737418240 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read))", "legendFormat": "hit ratio", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.9 },
            { "color": "green", "value": 0.99 }
          ]}
        }
      }
    },
    {
      "type": "row",
      "title": "Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Connections by State",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "pg_stat_activity_count", "legendFormat": "{{state}}" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 15, "lineWidth": 2, "stacking": { "mode": "normal" } } }
      }
    },
    {
      "type": "timeseries",
      "title": "Transactions / s",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_xact_commit[5m]))", "legendFormat": "commits" },
        { "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "rollbacks" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "commits" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "rollbacks" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "type": "row",
      "title": "Operations",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Tuple Operations / s",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_tup_fetched[5m]))", "legendFormat": "fetched" },
        { "expr": "sum(rate(pg_stat_database_tup_inserted[5m]))", "legendFormat": "inserted" },
        { "expr": "sum(rate(pg_stat_database_tup_updated[5m]))", "legendFormat": "updated" },
        { "expr": "sum(rate(pg_stat_database_tup_deleted[5m]))", "legendFormat": "deleted" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "fetched" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "inserted" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "updated" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "deleted" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "type": "stat",
      "title": "Deadlocks",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pg_stat_database_deadlocks)", "legendFormat": "deadlocks", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nova", "infrastructure", "postgres"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Nova PostgreSQL",
  "uid": "nova-postgres",
  "version": 1
}
