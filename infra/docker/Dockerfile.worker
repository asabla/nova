# syntax=docker/dockerfile:1

# Bun for fast deps install + build, Node.js for Temporal runtime
FROM oven/bun:1-alpine AS builder

WORKDIR /app

COPY package.json bun.lock* ./
COPY packages/shared/package.json packages/shared/
COPY packages/api/package.json packages/api/
COPY packages/web/package.json packages/web/
COPY packages/worker/package.json packages/worker/

RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile

COPY packages/shared/ packages/shared/
COPY packages/worker/ packages/worker/

# Clean stale build artifacts, then tsc -b builds shared + worker via project references
RUN rm -rf packages/shared/dist packages/worker/dist packages/shared/*.tsbuildinfo packages/worker/*.tsbuildinfo && \
    cd packages/worker && bunx tsc -b

# Production deps only
RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile --production

# Strip TypeScript source from @openai/agents-core to prevent tsx from
# loading .ts files instead of compiled .js (causes zod v3 compat issues)
RUN rm -rf node_modules/@openai/agents-core/src \
           node_modules/@openai/agents-openai/src

# Patch: agents-core uses .superRefine() on ComputerUseCallItem which produces
# ZodEffects — but zod v3 compat discriminatedUnion requires ZodObject with .shape.
# Remove the .superRefine() call so the discriminated union can read the discriminator.
RUN for f in node_modules/@openai/agents-core/dist/types/protocol.mjs \
             node_modules/@openai/agents-core/dist/types/protocol.js; do \
      bun -e " \
        const code = await Bun.file('$f').text(); \
        const patched = code.replace(/\}\)\.superRefine\(\(value,\s*ctx\)\s*=>\s*\{[\s\S]*?\n\}\);/g, '});'); \
        await Bun.write('$f', patched); \
      "; \
    done

# ── Runtime (Node.js — required by Temporal) ─────
FROM node:22-slim

WORKDIR /app

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/shared ./packages/shared
COPY --from=builder /app/packages/worker ./packages/worker
COPY --from=builder /app/package.json ./

CMD ["npx", "tsx", "packages/worker/dist/index.js"]
