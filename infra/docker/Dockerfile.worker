# syntax=docker/dockerfile:1

# Parameterized worker build — pass WORKER_PACKAGE to select which worker to build.
# Usage: docker build --build-arg WORKER_PACKAGE=worker-agent -f infra/docker/Dockerfile.worker .
ARG WORKER_PACKAGE=worker-agent

# ── Stage 1: Shared base — deps install, patches, shared source build (cached across all workers) ──
#
# Using the debian-slim variant (not alpine) so @temporalio/core-bridge's
# glibc prebuilt binaries match the node:22-slim runtime stage and dlopen
# cleanly during bundleWorkflowCode at build time.
#
# Both oven/bun images ship a `node` shim at /usr/local/bun-node-fallback-bin
# that forwards to bun. That breaks webpack internals used by the bundle
# step, so we install real Node.js and remove the shim.
FROM oven/bun:1 AS base

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -f /usr/local/bun-node-fallback-bin/node && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy all workspace package.json files for dependency resolution
COPY package.json bun.lock* ./
COPY packages/shared/package.json packages/shared/
COPY packages/protocol/package.json packages/protocol/
COPY packages/gateway/package.json packages/gateway/
COPY packages/sdk-ts/package.json packages/sdk-ts/
COPY packages/worker-shared/package.json packages/worker-shared/
COPY packages/worker-agent/package.json packages/worker-agent/
COPY packages/worker-ingestion/package.json packages/worker-ingestion/
COPY packages/worker-background/package.json packages/worker-background/
COPY packages/admin/package.json packages/admin/
COPY packages/api/package.json packages/api/
COPY packages/web/package.json packages/web/

RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile

# Patch: agents-core uses .superRefine() on ComputerUseCallItem which produces
# ZodEffects — but zod v3 compat discriminatedUnion requires ZodObject with .shape.
RUN for f in node_modules/@openai/agents-core/dist/types/protocol.mjs \
             node_modules/@openai/agents-core/dist/types/protocol.js; do \
      bun -e " \
        const code = await Bun.file('$f').text(); \
        const patched = code.replace(/\}\)\.superRefine\(\(value,\s*ctx\)\s*=>\s*\{[\s\S]*?\n\}\);/g, '});'); \
        await Bun.write('$f', patched); \
      "; \
    done

# Copy and build shared packages (same for all workers)
COPY packages/shared/ packages/shared/
COPY packages/protocol/ packages/protocol/
COPY packages/gateway/ packages/gateway/
COPY packages/sdk-ts/ packages/sdk-ts/
COPY packages/worker-shared/ packages/worker-shared/

RUN rm -rf packages/shared/dist packages/protocol/dist packages/gateway/dist \
           packages/sdk-ts/dist packages/worker-shared/dist \
           packages/shared/*.tsbuildinfo packages/protocol/*.tsbuildinfo \
           packages/gateway/*.tsbuildinfo packages/sdk-ts/*.tsbuildinfo \
           packages/worker-shared/*.tsbuildinfo && \
    cd packages/worker-shared && bunx tsc -b

# ── Stage 2: Worker-specific build ──
FROM base AS builder

ARG WORKER_PACKAGE

# Copy only the target worker's source (this layer varies per worker)
COPY packages/${WORKER_PACKAGE}/ packages/${WORKER_PACKAGE}/

# Build the worker: tsc compiles TS → dist/, then bundleWorkflowCode
# emits dist/workflow-bundle.js for Temporal's workflow sandbox.
RUN rm -rf packages/${WORKER_PACKAGE}/dist packages/${WORKER_PACKAGE}/*.tsbuildinfo && \
    cd packages/${WORKER_PACKAGE} && bun run build

# The base stage already installed all deps (including dev) and patched
# @openai/agents-core. We intentionally skip a second `bun install --production`
# and the second patch pass: the install reinstates roughly the same tree we
# just had and the patch has to run again to cover it. That round-trip cost
# ~0.5-2s per build and made the Dockerfile harder to reason about. The
# tradeoff is ~50-80 MB of dev deps (typescript, @types/*) in the final image.
#
# Note: zod 3.25+ has native ./v3 and ./v4 sub-path exports — no shims needed.

# ── Stage 3: Runtime (Node.js — required by Temporal) ──
FROM node:22-slim

# git is needed at runtime for repository connector (clone, diff, ls-remote)
RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

ARG WORKER_PACKAGE

WORKDIR /app

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/shared ./packages/shared
COPY --from=builder /app/packages/protocol ./packages/protocol
COPY --from=builder /app/packages/gateway ./packages/gateway
COPY --from=builder /app/packages/sdk-ts ./packages/sdk-ts
COPY --from=builder /app/packages/worker-shared ./packages/worker-shared
COPY --from=builder /app/packages/${WORKER_PACKAGE} ./packages/${WORKER_PACKAGE}
COPY --from=builder /app/package.json ./

USER node

ENV WORKER_PACKAGE=${WORKER_PACKAGE}
# tsx (not plain `node`) because worker-shared/src/*.ts files import their
# siblings without a `.js` extension — a TypeScript convention that's fine
# under bundlers and tsx but breaks pure Node ESM resolution. tsx's loader
# handles the resolution transparently and shipping it at runtime is
# cheap. Adding explicit `.js` extensions everywhere was considered and
# rejected as excessive churn for this cleanup pass.
CMD npx tsx packages/${WORKER_PACKAGE}/dist/index.js
