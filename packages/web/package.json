{
  "name": "@nova/web",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "storybook:gap": "bun run scripts/storybook-gap-analysis.ts",
    "postinstall": "mkdir -p public/excalidraw-assets && cp -r ../../node_modules/@excalidraw/excalidraw/dist/prod/fonts ../../node_modules/@excalidraw/excalidraw/dist/prod/data public/excalidraw-assets/ 2>/dev/null || true"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@excalidraw/mermaid-to-excalidraw": "^2.1.1",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@nova/shared": "workspace:*",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-router": "^1.168.10",
    "better-auth": "^1.5.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "diff": "^8.0.3",
    "dompurify": "^3.2.6",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.0.4",
    "katex": "^0.16.21",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.14.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "reconnecting-websocket": "^4.4.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.1",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-themes": "^10.3.4",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/vite": "^4.1.4",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/diff": "^8.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.1",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.1.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
