    "@temporalio/client": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "@temporalio/workflow": "^1.11.7",
    "drizzle-orm": "^0.45.2",
    "openai": "^6.27.0",
    "tsx": "^4.19.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/node": "^25.5.0"
  }
