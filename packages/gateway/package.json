{
  "name": "@nova/gateway",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "default": "./src/app.ts"
    },
    "./jwt": {
      "types": "./dist/middleware/jwt-auth.d.ts",
      "default": "./src/middleware/jwt-auth.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.2",
    "@nova/protocol": "workspace:*",
    "@nova/shared": "workspace:*",
    "@nova/worker-shared": "workspace:*",
    "hono": "^4.7.9",
    "jose": "^6.0.11",
    "pino": "^10.3.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2"
  }
}
