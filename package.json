{
  "name": "nova",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/protocol",
    "packages/gateway",
    "packages/sdk-ts",
    "packages/worker-shared",
    "packages/worker-agent",
    "packages/worker-ingestion",
    "packages/worker-background",
    "packages/api",
    "packages/web",
    "packages/admin"
  ],
  "scripts": {
    "postinstall": "sed -i.bak 's/z\\.function().returns(z\\.array(z\\.string()))/z.custom()/g' node_modules/@tanstack/router-generator/dist/esm/config.js node_modules/@tanstack/router-generator/dist/cjs/config.cjs 2>/dev/null; rm -f node_modules/@tanstack/router-generator/dist/esm/config.js.bak node_modules/@tanstack/router-generator/dist/cjs/config.cjs.bak",
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter @nova/api dev",
    "dev:web": "bun run --filter @nova/web dev",
    "dev:worker:agent": "bun run --filter @nova/worker-agent dev",
    "dev:worker:ingestion": "bun run --filter @nova/worker-ingestion dev",
    "dev:worker:background": "bun run --filter @nova/worker-background dev",
    "dev:workers": "bun run --filter '@nova/worker-*' dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "typecheck": "tsc -b packages/shared/tsconfig.json && bun run --filter '*' typecheck",
    "db:generate": "bun run --filter @nova/api db:generate",
    "db:migrate": "bun run --filter @nova/api db:migrate",
    "db:push": "bun run --filter @nova/api db:push",
    "db:studio": "bun run --filter @nova/api db:studio",
    "storybook": "bun run --filter @nova/web storybook",
    "storybook:build": "bun run --filter @nova/web storybook:build"
  },
  "overrides": {
    "zod": "^4.3.6"
  },
  "resolutions": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2"
  }
}
